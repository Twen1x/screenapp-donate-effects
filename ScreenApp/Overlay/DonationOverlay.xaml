<Window x:Class="ScreenApp.Overlay.DonationOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <!-- Полупрозрачная «плашка» с подписью «ник — сумма — действие».
         Видимость управляется анимацией прозрачности (fade in/out, R5.4). -->
    <Border x:Name="Plate"
            Background="#CC000000"
            CornerRadius="10"
            Padding="22,12"
            Opacity="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.6" Color="Black" />
        </Border.Effect>
        <TextBlock x:Name="MessageText"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="SemiBold"
                   TextAlignment="Center"
                   Text="ник — сумма — действие" />
    </Border>
</Window>
